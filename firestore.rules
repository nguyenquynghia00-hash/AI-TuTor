rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // Domain Validators
    function isValidUserProfile() {
      return hasRequiredFields(['uid', 'displayName', 'email', 'createdAt']) &&
             request.resource.data.uid == request.auth.uid &&
             validStringLength('displayName', 1, 100) &&
             request.resource.data.email is string &&
             request.resource.data.createdAt is string &&
             (!('friends' in request.resource.data) || request.resource.data.friends is list);
    }

    function isValidPost() {
      return hasRequiredFields(['id', 'authorId', 'authorName', 'authorAvatar', 'content', 'timestamp', 'likes', 'comments']) &&
             request.resource.data.authorId == request.auth.uid &&
             validStringLength('authorName', 1, 100) &&
             request.resource.data.authorAvatar is string &&
             request.resource.data.content is string &&
             request.resource.data.content.size() <= 5000 &&
             request.resource.data.timestamp is string &&
             request.resource.data.likes is list &&
             request.resource.data.comments is list &&
             (!('media' in request.resource.data) || (
               request.resource.data.media is map &&
               request.resource.data.media.type in ['image', 'video', 'file'] &&
               request.resource.data.media.url is string
             ));
    }

    function isValidMessage() {
      return hasRequiredFields(['id', 'senderId', 'receiverId', 'content', 'timestamp']) &&
             request.resource.data.senderId == request.auth.uid &&
             validStringLength('content', 1, 5000) &&
             request.resource.data.timestamp is string;
    }

    function isValidFriendship() {
      return hasRequiredFields(['user1Id', 'user2Id', 'status', 'timestamp']) &&
             (request.resource.data.user1Id == request.auth.uid || request.resource.data.user2Id == request.auth.uid) &&
             request.resource.data.status in ['pending', 'accepted'] &&
             request.resource.data.timestamp is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUserProfile();
      allow update: if isOwner(userId) && isValidUserProfile();
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost();
      allow update: if isAuthenticated() && 
                    // Either the owner is updating the post content
                    ((request.resource.data.authorId == request.auth.uid && 
                      request.resource.data.authorId == resource.data.authorId &&
                      isValidPost()) ||
                    // Or someone is liking/commenting (only likes and comments change)
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'comments']) &&
                      request.resource.data.authorId == resource.data.authorId &&
                      request.resource.data.content == resource.data.content &&
                      request.resource.data.timestamp == resource.data.timestamp));
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuthenticated() && isValidMessage();
      allow update: if false; // Messages cannot be updated
      allow delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }

    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && (resource.data.user1Id == request.auth.uid || resource.data.user2Id == request.auth.uid);
      allow create: if isAuthenticated() && isValidFriendship();
      allow update: if isAuthenticated() && isValidFriendship() && 
                    // Only the receiver can accept the friendship
                    (resource.data.status == 'pending' && request.resource.data.status == 'accepted' && 
                     (resource.data.user2Id == request.auth.uid || resource.data.user1Id == request.auth.uid));
      allow delete: if isAuthenticated() && (resource.data.user1Id == request.auth.uid || resource.data.user2Id == request.auth.uid);
    }
  }
}
